<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="inspire_rh56_hand_ros2_control" params="
    name
    serial_port:=/dev/ttyUSB0
    baudrate:=115200
    use_mock_hardware:=false
    ">

    <ros2_control name="${name}" type="system">

      <!-- Hardware interface plugin -->
      <hardware>
        <xacro:if value="${use_mock_hardware}">
          <plugin>mock_components/GenericSystem</plugin>
          <param name="state_following_offset">0.0</param>
        </xacro:if>
        <xacro:unless value="${use_mock_hardware}">
          <plugin>inspire_rh56_hand_ros2_control/InspireRH56HandHardwareInterface</plugin>
          <param name="serial_port">${serial_port}</param>
          <param name="baudrate">${baudrate}</param>
        </xacro:unless>
      </hardware>

      <!-- Joint definitions -->
      <!-- Thumb joints -->
      <joint name="thumb_proximal_yaw_joint">
        <command_interface name="position">
          <param name="min">0.0</param>
          <param name="max">1.308</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <joint name="thumb_proximal_pitch_joint">
        <command_interface name="position">
          <param name="min">0.0</param>
          <param name="max">0.6</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <!-- Four finger joints -->
      <joint name="index_proximal_joint">
        <command_interface name="position">
          <param name="min">0.0</param>
          <param name="max">1.47</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <joint name="middle_proximal_joint">
        <command_interface name="position">
          <param name="min">0.0</param>
          <param name="max">1.47</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <joint name="ring_proximal_joint">
        <command_interface name="position">
          <param name="min">0.0</param>
          <param name="max">1.47</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <joint name="pinky_proximal_joint">
        <command_interface name="position">
          <param name="min">0.0</param>
          <param name="max">1.47</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

    </ros2_control>

  </xacro:macro>

</robot>